# 环境配置
APP_NAME=Snipe-CN
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Shanghai

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=snipe_cn
DB_USERNAME=snipe_user
DB_PASSWORD=snipe_password
DB_ROOT_PASSWORD=root_password

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379

# 端口配置
BACKEND_PORT=8000
FRONTEND_PORT=5173
NGINX_PORT=80
DB_PORT=3306
REDIS_PORT_LOCAL=6379

# 前端配置
VITE_API_URL=http://localhost:8000

# 邮件配置(可选)
MAIL_MAILER=smtp
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your@qq.com
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@snipe.cn
MAIL_FROM_NAME=Snipe-CN

# 系统配置
CURRENCY=CNY
DATE_FORMAT=Y-m-d
TIME_FORMAT=H:i:s

# 微信通知配置(可选)
WECHAT_ENABLED=false
WECHAT_WEBHOOK_URL=
WECHAT_NOTIFY_ASSET_EXPIRING=true
WECHAT_NOTIFY_ASSET_CHANGED=true
WECHAT_NOTIFY_INVENTORY_CREATED=true
WECHAT_NOTIFY_INVENTORY_COMPLETED=true
